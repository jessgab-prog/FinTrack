<Window x:Class="FinTrack.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FinTrack" Height="520" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="/Logo-FinTrack.ico"
        Background="#F5F5F0">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="180"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1D9E75" CornerRadius="0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                Margin="0,20,0,20">
                <Border Width="80" Height="80" CornerRadius="16"
                HorizontalAlignment="Center" Margin="0,0,0,12">
                    <Image Source="/Logo-FinTrack.ico"
                           Width="80" Height="80"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
                <TextBlock Text="FinTrack" FontSize="24" FontWeight="SemiBold"
                   Foreground="White" HorizontalAlignment="Center"
                   Margin="0,0,0,2"/>
                <TextBlock Text="Small Business Finance Manager"
                   FontSize="12" Foreground="#A8DFC9"
                   HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Login Form -->
        <StackPanel Grid.Row="1" Margin="40,30,40,0">

            <TextBlock Text="Username" FontSize="12"
                       Foreground="#555" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtUsername" Height="38" FontSize="14"
                     Padding="10,0" VerticalContentAlignment="Center"
                     BorderBrush="#DDD" BorderThickness="1"
                     Background="White"/>

            <TextBlock Text="Password" FontSize="12"
           Foreground="#555" Margin="0,16,0,4"/>
            <Grid>
                <PasswordBox x:Name="TxtPassword" Height="38" FontSize="14"
                 Padding="10,0" VerticalContentAlignment="Center"
                 BorderBrush="#DDD" BorderThickness="1"
                 Background="White"/>
                <TextBox x:Name="TxtPasswordVisible" Height="38" FontSize="14"
             Padding="10,0" VerticalContentAlignment="Center"
             BorderBrush="#DDD" BorderThickness="1"
             Background="White" Visibility="Collapsed"/>
                <Button x:Name="BtnToggleLogin" Width="36" Height="36"
        HorizontalAlignment="Right" Margin="0,0,2,0"
        Background="Transparent" BorderThickness="0"
        Cursor="Hand" Click="BtnToggleLogin_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent"
                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Path x:Name="EyePath"
          Fill="#888888"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Stretch="Uniform" Width="20" Height="14"
          Data="M12,4.5C7,4.5 2.73,7.61 1,12c1.73,4.39 6,7.5 11,7.5s9.27-3.11 11-7.5C21.27,7.61 17,4.5 12,4.5z M12,17c-2.76,0-5-2.24-5-5s2.24-5 5-5 5,2.24 5,5-2.24,5-5,5z M12,9c-1.66,0-3,1.34-3,3s1.34,3 3,3 3-1.34 3-3-1.34-3-3-3z"/>
                </Button>
            </Grid>

            <!-- Error message -->
            <TextBlock x:Name="TxtError" Foreground="#E24B4A"
                       FontSize="12" Margin="0,10,0,0"
                       TextWrapping="Wrap" Visibility="Collapsed"/>

            <Button x:Name="BtnLogin" Content="Sign In"
                    Height="42" Margin="0,24,0,0"
                    Background="#1D9E75" Foreground="White"
                    FontSize="14" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnLogin_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <TextBlock Margin="0,20,0,0" HorizontalAlignment="Center"
                       FontSize="11" Foreground="#999">
                Default: admin / admin123
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>