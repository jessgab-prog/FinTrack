<Window x:Class="FinTrack.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FinTrack" Height="520" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F0">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="180"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1D9E75" CornerRadius="0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Background="#0F6E56" Width="56" Height="56"
                        CornerRadius="12" HorizontalAlignment="Center">
                    <TextBlock Text="₱" FontSize="28" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="FinTrack" FontSize="24" FontWeight="SemiBold"
                           Foreground="White" HorizontalAlignment="Center"
                           Margin="0,10,0,2"/>
                <TextBlock Text="Small Business Finance Manager"
                           FontSize="12" Foreground="#A8DFC9"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Login Form -->
        <StackPanel Grid.Row="1" Margin="40,30,40,0">

            <TextBlock Text="Username" FontSize="12"
                       Foreground="#555" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtUsername" Height="38" FontSize="14"
                     Padding="10,0" VerticalContentAlignment="Center"
                     BorderBrush="#DDD" BorderThickness="1"
                     Background="White"/>

            <TextBlock Text="Password" FontSize="12"
                       Foreground="#555" Margin="0,16,0,4"/>
            <PasswordBox x:Name="TxtPassword" Height="38" FontSize="14"
                         Padding="10,0" VerticalContentAlignment="Center"
                         BorderBrush="#DDD" BorderThickness="1"
                         Background="White"/>

            <!-- Error message -->
            <TextBlock x:Name="TxtError" Foreground="#E24B4A"
                       FontSize="12" Margin="0,10,0,0"
                       TextWrapping="Wrap" Visibility="Collapsed"/>

            <Button x:Name="BtnLogin" Content="Sign In"
                    Height="42" Margin="0,24,0,0"
                    Background="#1D9E75" Foreground="White"
                    FontSize="14" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnLogin_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <TextBlock Margin="0,20,0,0" HorizontalAlignment="Center"
                       FontSize="11" Foreground="#999">
                Default: admin / admin123
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>