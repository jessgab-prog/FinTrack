<Window x:Class="FinTrack.Views.TransactionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transaction" Height="580" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F0">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">
            <TextBlock x:Name="TxtTitle" Text="Add Transaction"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="#1A1A1A" Margin="0,0,0,20"/>

            <TextBlock Text="Type" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbType" Height="36" FontSize="13"
                      BorderBrush="#DDD" Margin="0,0,0,12">
                <ComboBoxItem Content="Income"/>
                <ComboBoxItem Content="Expense" IsSelected="True"/>
            </ComboBox>

            <TextBlock Text="Description" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtDescription" Height="36" FontSize="13"
                     Padding="10,0" VerticalContentAlignment="Center"
                     BorderBrush="#DDD" Margin="0,0,0,12"/>

            <TextBlock Text="Amount (₱)" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtAmount" Height="36" FontSize="13"
                     Padding="10,0" VerticalContentAlignment="Center"
                     BorderBrush="#DDD" Margin="0,0,0,12"/>

            <TextBlock Text="Payment Method" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbPayment" Height="36" FontSize="13"
                      BorderBrush="#DDD" Margin="0,0,0,12">
                <ComboBoxItem Content="Cash" IsSelected="True"/>
                <ComboBoxItem Content="GCash"/>
                <ComboBoxItem Content="Maya"/>
                <ComboBoxItem Content="Bank"/>
            </ComboBox>

            <TextBlock Text="Category" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbCategory" Height="36" FontSize="13"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      BorderBrush="#DDD" Margin="0,0,0,12"/>

            <TextBlock Text="Client / Vendor (optional)" FontSize="12"
                       Foreground="#555" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbClient" Height="36" FontSize="13"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      BorderBrush="#DDD" Margin="0,0,0,12"/>

            <TextBlock Text="Date" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
            <DatePicker x:Name="DpDate" Height="36" FontSize="13"
                        BorderBrush="#DDD" Margin="0,0,0,24"/>

            <TextBlock x:Name="TxtError" Foreground="#E24B4A"
                       FontSize="12" Margin="0,0,0,8"
                       Visibility="Collapsed"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Cancel" Height="38"
                        Margin="0,0,6,0" Background="#EEE"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnCancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Grid.Column="1" x:Name="BtnSave"
                        Content="Save" Height="38"
                        Margin="6,0,0,0"
                        Background="#1D9E75" Foreground="White"
                        FontWeight="SemiBold" BorderThickness="0"
                        Cursor="Hand" Click="BtnSave_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>

            <!-- Bottom padding -->
            <Border Height="16"/>
        </StackPanel>
    </ScrollViewer>
</Window>