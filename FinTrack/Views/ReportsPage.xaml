<Page x:Class="FinTrack.Views.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F5F0">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TxtTitle" Text="Reports"
                       FontSize="20" FontWeight="SemiBold" Foreground="#1A1A1A"/>
            <ComboBox x:Name="CmbMonth" Grid.Column="1"
                      Height="36" Width="140" Margin="0,0,8,0"
                      FontSize="13" BorderBrush="#DDD"
                      SelectionChanged="CmbMonth_Changed"/>
            <ComboBox x:Name="CmbYear" Grid.Column="2"
                      Height="36" Width="90"
                      FontSize="13" BorderBrush="#DDD"
                      SelectionChanged="CmbYear_Changed"/>
        </Grid>

        <!-- Summary cards -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" x:Name="CardIncome"
                    Background="White" CornerRadius="10"
                    BorderBrush="#E8E8E2" BorderThickness="1"
                    Margin="0,0,10,0" Padding="16">
                <StackPanel>
                    <TextBlock Text="Total Income" FontSize="11" Foreground="#888"/>
                    <TextBlock x:Name="TxtRptIncome" Text="₱0.00"
                               FontSize="22" FontWeight="SemiBold"
                               Foreground="#1D9E75" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" x:Name="CardExpense"
                    Background="White" CornerRadius="10"
                    BorderBrush="#E8E8E2" BorderThickness="1"
                    Margin="0,0,10,0" Padding="16">
                <StackPanel>
                    <TextBlock Text="Total Expenses" FontSize="11" Foreground="#888"/>
                    <TextBlock x:Name="TxtRptExpense" Text="₱0.00"
                               FontSize="22" FontWeight="SemiBold"
                               Foreground="#E24B4A" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" x:Name="CardNet"
                    Background="White" CornerRadius="10"
                    BorderBrush="#E8E8E2" BorderThickness="1"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Net Profit / Loss" FontSize="11" Foreground="#888"/>
                    <TextBlock x:Name="TxtRptNet" Text="₱0.00"
                               FontSize="22" FontWeight="SemiBold"
                               Foreground="#1A1A1A" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Breakdown table -->
        <Border Grid.Row="2" x:Name="CardTable"
                Background="White" CornerRadius="10"
                BorderBrush="#E8E8E2" BorderThickness="1"
                Padding="16">
            <StackPanel>
                <TextBlock x:Name="TxtTableTitle"
                           Text="Transaction Breakdown"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#1A1A1A" Margin="0,0,0,12"/>
                <DataGrid x:Name="DgReport"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          RowHeight="40" FontSize="13"
                          Background="White"
                          AlternatingRowBackground="#FAFAF8"
                          CanUserResizeRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Width="110"
                            Binding="{Binding Date, StringFormat={}{0:MMM dd yyyy}}"/>
                        <DataGridTextColumn Header="Description" Width="*"
                            Binding="{Binding Description}"/>
                        <DataGridTextColumn Header="Category" Width="130"
                            Binding="{Binding Category.Name}"/>
                        <DataGridTextColumn Header="Type" Width="90"
                            Binding="{Binding Type}"/>
                        <DataGridTextColumn Header="Method" Width="100"
                            Binding="{Binding PaymentMethod}"/>
                        <DataGridTextColumn Header="Amount (₱)" Width="120"
                            Binding="{Binding Amount, StringFormat=N2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="0,0,12,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</Page>