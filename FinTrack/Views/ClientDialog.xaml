<Window x:Class="FinTrack.Views.ClientDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Client" Height="520" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" Background="#F5F5F0">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">
            <TextBlock x:Name="TxtTitle" Text="Add Client"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="#1A1A1A" Margin="0,0,0,20"/>

            <TextBlock Text="Type" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbType" Height="36" FontSize="13"
                      BorderBrush="#DDD" Margin="0,0,0,12">
                <ComboBoxItem Content="Client" IsSelected="True"/>
                <ComboBoxItem Content="Vendor"/>
            </ComboBox>

            <TextBlock Text="Full Name" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtName" Height="36" FontSize="13"
                     Padding="10,0" VerticalContentAlignment="Center"
                     BorderBrush="#DDD" Margin="0,0,0,12"/>

            <TextBlock Text="Contact Number" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtContact" Height="36" FontSize="13"
                     Padding="10,0" VerticalContentAlignment="Center"
                     BorderBrush="#DDD" Margin="0,0,0,12"/>

            <TextBlock Text="Email" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtEmail" Height="36" FontSize="13"
                     Padding="10,0" VerticalContentAlignment="Center"
                     BorderBrush="#DDD" Margin="0,0,0,12"/>

            <TextBlock Text="Address" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtAddress" Height="36" FontSize="13"
                     Padding="10,0" VerticalContentAlignment="Center"
                     BorderBrush="#DDD" Margin="0,0,0,20"/>

            <TextBlock x:Name="TxtError" Foreground="#E24B4A"
                       FontSize="12" Margin="0,0,0,8"
                       Visibility="Collapsed"/>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Cancel" Height="42"
                        Margin="0,0,6,0" Background="#EEE"
                        Foreground="#444" FontSize="13"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnCancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Grid.Column="1" Content="Save" Height="42"
                        Margin="6,0,0,0"
                        Background="#1D9E75" Foreground="White"
                        FontSize="13" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnSave_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Window>