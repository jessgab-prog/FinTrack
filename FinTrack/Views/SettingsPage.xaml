<Page x:Class="FinTrack.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F5F0">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="600">

            <TextBlock x:Name="TxtTitle" Text="Settings"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="#1A1A1A" Margin="0,0,0,24"/>

            <!-- Profile Card -->
            <Border x:Name="CardProfile" Background="White" CornerRadius="10"
                    BorderBrush="#E8E8E2" BorderThickness="1"
                    Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Profile" FontSize="14" FontWeight="SemiBold"
                               Foreground="#1A1A1A" Margin="0,0,0,16"/>

                    <TextBlock Text="Full Name" FontSize="12"
                               Foreground="#555" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtFullName" Height="36" FontSize="13"
                             Padding="10,0" VerticalContentAlignment="Center"
                             BorderBrush="#DDD" Margin="0,0,0,12"/>

                    <TextBlock Text="Username" FontSize="12"
                               Foreground="#555" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtUsername" Height="36" FontSize="13"
                             Padding="10,0" VerticalContentAlignment="Center"
                             BorderBrush="#DDD" Margin="0,0,0,12"/>

                    <TextBlock x:Name="TxtProfileMsg" FontSize="12"
                               Margin="0,0,0,8" Visibility="Collapsed"/>

                    <Button Content="Save Profile" Height="38" Width="140"
                            HorizontalAlignment="Left"
                            Background="#1D9E75" Foreground="White"
                            FontWeight="SemiBold" BorderThickness="0"
                            Cursor="Hand" Click="BtnSaveProfile_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Change Password Card -->
            <Border x:Name="CardPassword" Background="White" CornerRadius="10"
                    BorderBrush="#E8E8E2" BorderThickness="1"
                    Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Change Password" FontSize="14"
                               FontWeight="SemiBold" Foreground="#1A1A1A"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="Current Password" FontSize="12"
                               Foreground="#555" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="TxtCurrentPw" Height="36" FontSize="13"
                                 Padding="10,0" BorderBrush="#DDD"
                                 Margin="0,0,0,12"/>

                    <TextBlock Text="New Password" FontSize="12"
                               Foreground="#555" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="TxtNewPw" Height="36" FontSize="13"
                                 Padding="10,0" BorderBrush="#DDD"
                                 Margin="0,0,0,12"/>

                    <TextBlock Text="Confirm New Password" FontSize="12"
                               Foreground="#555" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="TxtConfirmPw" Height="36" FontSize="13"
                                 Padding="10,0" BorderBrush="#DDD"
                                 Margin="0,0,0,12"/>

                    <TextBlock x:Name="TxtPwMsg" FontSize="12"
                               Margin="0,0,0,8" Visibility="Collapsed"/>

                    <Button Content="Change Password" Height="38" Width="160"
                            HorizontalAlignment="Left"
                            Background="#1D9E75" Foreground="White"
                            FontWeight="SemiBold" BorderThickness="0"
                            Cursor="Hand" Click="BtnChangePw_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <!-- App Info Card -->
            <Border x:Name="CardInfo" Background="White" CornerRadius="10"
                    BorderBrush="#E8E8E2" BorderThickness="1"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="About" FontSize="14" FontWeight="SemiBold"
                               Foreground="#1A1A1A" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Application" FontSize="12"
                                   Foreground="#888" Margin="0,0,0,8"/>
                        <TextBlock Grid.Column="1" Text="FinTrack"
                                   FontSize="12" Foreground="#1A1A1A"
                                   Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Text="Version" FontSize="12"
                                   Foreground="#888" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="1.0.0"
                                   FontSize="12" Foreground="#1A1A1A"
                                   Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="2" Text="Platform" FontSize="12"
                                   Foreground="#888"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text=".NET 8 · WPF · SQLite"
                                   FontSize="12" Foreground="#1A1A1A"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>