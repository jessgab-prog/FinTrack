<Page x:Class="FinTrack.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Background="#F5F5F0">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- Welcome row -->
            <TextBlock x:Name="TxtWelcome" FontSize="20"
                       FontWeight="SemiBold" Foreground="#1A1A1A"
                       Margin="0,0,0,4"/>
            <TextBlock x:Name="TxtDate" FontSize="12"
                       Foreground="#888" Margin="0,0,0,20"/>

            <!-- KPI Cards -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Income -->
                <Border Grid.Column="0" Background="White" CornerRadius="10"
                        BorderBrush="#E8E8E2" BorderThickness="1"
                        Margin="0,0,10,0" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Total Income" FontSize="11"
                                   Foreground="#888" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtIncome" Text="₱0.00"
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="#1D9E75"/>
                        <TextBlock x:Name="TxtIncomeCount" FontSize="11"
                                   Foreground="#AAA" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Expenses -->
                <Border Grid.Column="1" Background="White" CornerRadius="10"
                        BorderBrush="#E8E8E2" BorderThickness="1"
                        Margin="0,0,10,0" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Total Expenses" FontSize="11"
                                   Foreground="#888" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtExpenses" Text="₱0.00"
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="#E24B4A"/>
                        <TextBlock x:Name="TxtExpenseCount" FontSize="11"
                                   Foreground="#AAA" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Net Profit -->
                <Border Grid.Column="2" Background="White" CornerRadius="10"
                        BorderBrush="#E8E8E2" BorderThickness="1"
                        Margin="0,0,10,0" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Net Profit" FontSize="11"
                                   Foreground="#888" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtNet" Text="₱0.00"
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="#1A1A1A"/>
                        <TextBlock x:Name="TxtNetLabel" FontSize="11"
                                   Foreground="#AAA" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Transactions -->
                <!-- Transactions -->
                <Border Grid.Column="3" Background="White" CornerRadius="10"
        BorderBrush="#E8E8E2" BorderThickness="1"
        Padding="16">
                    <StackPanel>
                        <TextBlock Text="Transactions" FontSize="11"
                   Foreground="#888" Margin="0,0,0,8"/>

                        <TextBlock x:Name="TxtTxnCount" Text="0"
                   FontSize="22" FontWeight="SemiBold"
                   Foreground="#1A1A1A"/>

                        <TextBlock x:Name="TxtTxnSub"
                   Text="All time"
                   FontSize="11"
                   Foreground="#AAA"
                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Chart + Recent Transactions -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.6*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Bar Chart -->
                <Border Grid.Column="0" Background="White" CornerRadius="10"
                        BorderBrush="#E8E8E2" BorderThickness="1"
                        Margin="0,0,10,0" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Income vs Expenses — Last 6 Months"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#1A1A1A" Margin="0,0,0,12"/>
                        <lvc:CartesianChart x:Name="BarChart"
                                            Height="220"
                                            TooltipPosition="Top"/>
                    </StackPanel>
                </Border>

                <!-- Recent Transactions -->
                <Border Grid.Column="1" Background="White" CornerRadius="10"
                        BorderBrush="#E8E8E2" BorderThickness="1"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="Recent Transactions" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#1A1A1A"
                                   Margin="0,0,0,12"/>
                        <ItemsControl x:Name="RecentList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F0F0EA"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="12"
                                                           FontWeight="Medium"
                                                           Foreground="#1A1A1A"/>
                                                <TextBlock Text="{Binding Category.Name}"
                                                           FontSize="11"
                                                           Foreground="#999"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1"
                                                        HorizontalAlignment="Right">
                                                <TextBlock x:Name="TxtAmt"
                                                           Text="{Binding Amount, StringFormat=₱{0:N2}}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding Type, Converter={StaticResource TypeToColorConverter}}"
                                                           HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding Date, StringFormat={}{0:MMM dd}}"
                                                           FontSize="11" Foreground="#999"
                                                           HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Top Categories -->
            <Border Background="White" CornerRadius="10"
                    BorderBrush="#E8E8E2" BorderThickness="1"
                    Padding="16" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Top Expense Categories"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#1A1A1A" Margin="0,0,0,12"/>
                    <ItemsControl x:Name="CategoryList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="12" Foreground="#444"
                                               VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Height="8"
                                            CornerRadius="4"
                                            Background="#F0F0EA"
                                            Margin="0,0,12,0">
                                        <Border CornerRadius="4"
                                                Background="#1D9E75"
                                                HorizontalAlignment="Left"
                                                Width="{Binding BarWidth}"/>
                                    </Border>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Amount, StringFormat=₱{0:N2}}"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="#444"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>