<Window x:Class="FinTrack.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FinTrack" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F0">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border x:Name="SidebarBorder" Grid.Column="0" Background="#FFFFFF"
            BorderBrush="#E8E8E2" BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="16,18,16,14"
                        BorderBrush="#E8E8E2" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#1D9E75" Width="32" Height="32"
                                CornerRadius="8">
                            <TextBlock Text="₱" FontSize="16" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">

                            <TextBlock x:Name="TxtLogoName"
               Text="FinTrack"
               FontSize="14"
               FontWeight="SemiBold"
               Foreground="#1A1A1A"/>

                            <TextBlock x:Name="TxtLogoSub"
               Text="Finance Manager"
               FontSize="10"
               Foreground="#999"/>

                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- User info at bottom -->
                <Border DockPanel.Dock="Bottom" Padding="12,10"
        BorderBrush="#E8E8E2" BorderThickness="0,1,0,0">
                    <StackPanel>

                        <!-- User details -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#E1F5EE" Width="32" Height="32"
                    CornerRadius="16">
                                <TextBlock x:Name="TxtUserInitials"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#0F6E56"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Margin="8,0,0,0"
                        VerticalAlignment="Center">
                                <TextBlock x:Name="TxtUserName"
                           FontSize="12"
                           FontWeight="Medium"
                           Foreground="#1A1A1A"/>

                                <TextBlock x:Name="TxtUserRole"
                           FontSize="10"
                           Foreground="#999"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Logout button -->
                        <Button x:Name="BtnLogout"
                Content="⏻  Log Out"
                Height="34"
                HorizontalContentAlignment="Center"
                Background="#FDECEA"
                Foreground="#C0392B"
                FontSize="12"
                FontWeight="Medium"
                BorderThickness="0"
                Cursor="Hand"
                Click="BtnLogout_Click">

                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                    </StackPanel>
                </Border>

                <!-- Nav items -->
                <!-- Nav items -->
                <StackPanel Margin="8,12,8,0">

                    <TextBlock x:Name="LblMain"
               Text="MAIN"
               FontSize="10"
               Foreground="#AAAAAA"
               Margin="8,4,0,6"
               FontWeight="SemiBold"/>

                    <Button x:Name="BtnDashboard" Content="📊  Dashboard"
            Style="{StaticResource NavButton}"
            Click="NavButton_Click" Tag="Dashboard"/>

                    <Button x:Name="BtnTransactions" Content="💸  Transactions"
            Style="{StaticResource NavButton}"
            Click="NavButton_Click" Tag="Transactions"/>

                    <Button x:Name="BtnClients" Content="👥  Clients / Vendors"
            Style="{StaticResource NavButton}"
            Click="NavButton_Click" Tag="Clients"/>

                    <TextBlock x:Name="LblInsights"
               Text="INSIGHTS"
               FontSize="10"
               Foreground="#AAAAAA"
               Margin="8,14,0,6"
               FontWeight="SemiBold"/>

                    <Button x:Name="BtnReports" Content="📈  Reports"
            Style="{StaticResource NavButton}"
            Click="NavButton_Click" Tag="Reports"/>

                    <Button x:Name="BtnBudget" Content="🎯  Budget"
            Style="{StaticResource NavButton}"
            Click="NavButton_Click" Tag="Budget"/>

                    <Button x:Name="BtnNotifications" Content="🔔  Notifications"
            Style="{StaticResource NavButton}"
            Click="NavButton_Click" Tag="Notifications"/>

                    <TextBlock x:Name="LblSettings"
               Text="SETTINGS"
               FontSize="10"
               Foreground="#AAAAAA"
               Margin="8,14,0,6"
               FontWeight="SemiBold"/>

                    <Button x:Name="BtnSettings" Content="⚙️  Settings"
            Style="{StaticResource NavButton}"
            Click="NavButton_Click" Tag="Settings"/>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border x:Name="TopBarBorder" Grid.Row="0" Background="White"
                    BorderBrush="#E8E8E2" BorderThickness="0,0,0,1"
                    Padding="20,0">
                <DockPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TxtPageTitle"
                               Text="Dashboard"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="#1A1A1A"
                               VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <!-- Dark mode toggle -->
                        <ToggleButton x:Name="BtnDarkMode"
                                      Content="🌙 Dark"
                                      Height="30" Padding="10,0"
                                      Margin="0,0,8,0"
                                      FontSize="12"
                                      Checked="BtnDarkMode_Checked"
                                      Unchecked="BtnDarkMode_Unchecked"
                                      Style="{StaticResource ToggleThemeButton}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Page content frame -->
            <Frame x:Name="MainFrame" Grid.Row="1"
                   NavigationUIVisibility="Hidden"
                   Background="#F5F5F0"/>
        </Grid>
    </Grid>
</Window>